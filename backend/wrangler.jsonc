{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "kgdev-me-backend",
  "main": "build/worker/shim.mjs",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "cargo install -q worker-build && worker-build --release"
  },
  "workers_dev": false,
  "route": {
    "pattern": "blog-api.kgdev.me",
    "custom_domain": true
  },
  "dev": {
    "port": 8000
  },
  "placement": {
    "mode": "smart"
  },
  "observability": {
    "logs": {
      "enabled": true
    },
    "traces": {
      "enabled": true
    }
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "VIEW_COUNTER",
        "class_name": "ViewCounter"
      },
      {
        "name": "BLOG_POST_QA",
        "class_name": "BlogPostQA"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "ViewCounter"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "BlogPostQA"
      ]
    }
  ],
  "kv_namespaces": [
    {
      "binding": "BLOG_POST_QA_CACHE",
      "id": "ebdcf95e4fbe46719801f4de598840a7"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "ENVIRONMENT": "production",
    "CLOUDFLARE_SITEVERIFY_URL": "https://challenges.cloudflare.com/turnstile/v0/siteverify",
    "DESTINATION_EMAIL": "gray.kieran@protonmail.com",
    "ALLOWED_ORIGINS": "https://kgdev.me",
    "ALLOWED_BLOG_PATHS": "blog-view-counter,event-sourcing-cloudflare,quest-exactly-once-p1,quest-exactly-once-p2",
    "VECTORIZE_INDEX_NAME": "kgdev-me-blog",
    "EMBEDDING_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
    "GENERATION_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "QA_DAILY_CAP": "200"
  },
  "secrets": {
    "required": [
      "CLOUDFLARE_TURNSTILE_SECRET_KEY",
      "CLOUDFLARE_EMAIL_API_TOKEN",
      "CLOUDFLARE_ACCOUNT_ID",
      "CLOUDFLARE_VECTORIZE_API_TOKEN"
    ]
  },
  "env": {
    "dev": {
      "vars": {
        "ENVIRONMENT": "dev",
        "CLOUDFLARE_SITEVERIFY_URL": "https://challenges.cloudflare.com/turnstile/v0/siteverify",
        "DESTINATION_EMAIL": "gray.kieran@protonmail.com",
        "ALLOWED_ORIGINS": "",
        "ALLOWED_BLOG_PATHS": "blog-view-counter,event-sourcing-cloudflare,quest-exactly-once-p1,quest-exactly-once-p2",
        "VECTORIZE_INDEX_NAME": "kgdev-me-blog",
        "EMBEDDING_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
        "GENERATION_MODEL": "@cf/meta/llama-3.1-8b-instruct",
        "QA_DAILY_CAP": "50"
      },
      "secrets": {
        "required": [
          "CLOUDFLARE_TURNSTILE_SECRET_KEY",
          "CLOUDFLARE_EMAIL_API_TOKEN",
          "CLOUDFLARE_ACCOUNT_ID",
          "CLOUDFLARE_VECTORIZE_API_TOKEN"
        ]
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "VIEW_COUNTER",
            "class_name": "ViewCounter"
          },
          {
            "name": "BLOG_POST_QA",
            "class_name": "BlogPostQA"
          }
        ]
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": [
            "ViewCounter"
          ]
        },
        {
          "tag": "v2",
          "new_sqlite_classes": [
            "BlogPostQA"
          ]
        }
      ],
      "kv_namespaces": [
        {
          "binding": "BLOG_POST_QA_CACHE",
          "id": "ebdcf95e4fbe46719801f4de598840a7",
          "remote": true
        }
      ],
      "ai": {
        "binding": "AI"
      }
    }
  }
}