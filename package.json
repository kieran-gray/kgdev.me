{
    "name": "kgdev.me",
    "private": true,
    "workspaces": [
        "web",
        "services/contact-service",
        "services/view-counter"
    ],
    "devDependencies": {
        "concurrently": "^8.2.2",
        "@cloudflare/vitest-pool-workers": "^0.5.24",
        "prettier": "3.6.2",
        "prettier-plugin-astro": "0.14.1",
        "prettier-plugin-tailwindcss": "0.6.14",
        "wrangler": "^4.85.0"
    },
    "scripts": {
        "dev": "concurrently -n web,contact,counter \"npm run dev:web\" \"npm run dev:contact\" \"npm run dev:counter\"",
        "dev:web": "npm run dev --workspace=web",
        "dev:contact": "npm run dev --workspace=services/contact-service",
        "dev:counter": "npm run dev --workspace=services/view-counter",
        "format": "npm run format --workspaces --if-present",
        "build": "npm run build --workspaces --if-present",
        "build:web": "npm run build --workspace=web",
        "build:contact": "npm run build --workspace=services/contact-service",
        "build:counter": "npm run build --workspace=services/view-counter",
        "test": "npm run test --workspaces --if-present",
        "test:contact": "npm run test --workspace=services/contact-service",
        "test:counter": "npm run test --workspace=services/view-counter",
        "deploy": "npm run deploy --workspaces --if-present"
    }
}
