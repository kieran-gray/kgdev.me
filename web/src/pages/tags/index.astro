---
import Section from '@/components/layout/Section.astro';
import Tag from '@/components/ui/Tag.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import { siteConfig } from '@/config/site';
import { getTagBrowseDescription, getTagIndex } from '@/lib/content/tags';
import { features } from '@/config/features';

const title = `Tags | ${siteConfig.meta.title}`;
const description = getTagBrowseDescription();
const tagIndex = await getTagIndex();
---

<PageLayout head={{ title, description }} heading="Browse by Tag">
	<Section>
		<div class="mx-auto grid w-full max-w-screen-lg grid-cols-1 gap-2 px-4 sm:grid-cols-2 lg:grid-cols-3 md:px-0">
			{
				tagIndex.map(({ tag, counts }) => (
					<a href={`/tags/${tag}`} class="group">
						<div class="bg-[var(--card-outer-bg)] p-[1px] text-sm shadow-[inset_0_0_0_1px_rgba(255,255,255,0.4)] transition hover:bg-[var(--accent-700)]">
							<div class="flex items-center justify-between bg-[var(--card-inner-bg)] px-4 py-3 text-[var(--text-color)] opacity-95">
								<div class="flex items-center"><Tag tag={tag} /></div>
								<p class="text-xs text-[var(--muted-text)]">
									{features.projects.enabled ? `${counts.posts} posts · ${counts.projects} projects` : `${counts.posts} posts`}
								</p>
							</div>
						</div>
					</a>
				))
			}
		</div>
	</Section>
</PageLayout>
