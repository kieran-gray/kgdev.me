---
import { siteConfig } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/content/Hero.astro';
import LatestPosts from '@/components/content/LatestPosts.astro';
import LatestProjects from '@/features/projects/LatestProjects.astro';
import { getEntry, render } from 'astro:content';
import { getLatestPosts } from '@/lib/content/posts';
import { getHomepageProjects } from '@/lib/content/projects';
import { buildPersonSchema } from '@/lib/seo/jsonLd';

const { title } = siteConfig.meta;
const { description } = siteConfig.meta;

const latestPosts = await getLatestPosts(3);
const { projects: homepageProjects, title: projectsTitle } = await getHomepageProjects();

const homePage = await getEntry('pages', 'home');
if (!homePage) {
	throw new Error('Home page content entry not found');
}
const { Content } = await render(homePage);

const personSchema = buildPersonSchema();
---

<BaseLayout head={{ title, description }}>
	<Fragment slot="head">
		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</Fragment>
	<Hero headline={homePage.data.headline} currentRole={homePage.data.currentRole}>
		<Content />
	</Hero>
	<LatestPosts posts={latestPosts} />
	{homepageProjects.length > 0 && <LatestProjects projects={homepageProjects} title={projectsTitle} />}
</BaseLayout>
