---
import { siteConfig } from '@/config/site.config';
import Base from '@/layouts/Base.astro';
import Hero from '@/components/content/Hero.astro';
import LatestPosts from '@/components/content/LatestPosts.astro';
import LatestProjects from '@/components/content/LatestProjects.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getAllPosts } from '@/lib/content/posts';
import { buildPersonSchema } from '@/lib/seo/jsonLd';

const { title } = siteConfig.meta;
const { description } = siteConfig.meta;

const allPosts = await getAllPosts();
const latestPosts = allPosts.slice(0, 3);

const allProjects: CollectionEntry<'projects'>[] = await getCollection('projects');
const pinnedProjects = allProjects.filter((p) => p.data.pinned === true);
const homepageProjects = (pinnedProjects.length ? pinnedProjects : allProjects).slice(0, 2);
const projectsTitle = pinnedProjects.length ? 'Pinned Projects' : 'Latest Projects';

const personSchema = buildPersonSchema();
---

<Base head={{ title, description }}>
	<Fragment slot="head">
		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</Fragment>
	<Hero />
	<LatestPosts posts={latestPosts} />
	<LatestProjects projects={homepageProjects} title={projectsTitle} />
</Base>
