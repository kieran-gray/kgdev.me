---
import { siteConfig } from '@/config/site';
import PageLayout from '@/layouts/PageLayout.astro';
import Section from '@/components/layout/Section.astro';
import Card from '@/components/ui/Card.astro';
import { getAllPosts } from '@/lib/content/posts';

const title = `Posts | ${siteConfig.meta.title}`;
const description =
	'Technical blog posts on distributed systems, Rust, TypeScript, event sourcing, and Cloudflare Workers.';

const allPosts = await getAllPosts();
---

<PageLayout head={{ title, description }} heading="Posts">
	<Section>
		{
			allPosts.map((post) => (
				<div class="mb-4 basis-1 last:mb-0">
					<Card post={post} />
				</div>
			))
		}
	</Section>
</PageLayout>
