---
import Base from '@/layouts/Base.astro';
import Section from '@/components/layout/Section.astro';
import Heading from '@/components/ui/Heading.astro';
import CurrentlyReading from '@/components/books/CurrentlyReading.astro';
import BookList from '@/components/books/BookList.astro';

import { parseBooks, getCurrentlyReading, getReadHistory } from '@/lib/content/books';

const books = parseBooks();
const currentlyReading = getCurrentlyReading(books);
const readHistory = getReadHistory(books);
const years = Object.keys(readHistory).sort((a, b) => b.localeCompare(a));

const pageTitle = 'Books';
const pageDescription = 'A list of books I am currently reading and have read in the past.';

function formatDate(dateStr: string) {
	const date = new Date(dateStr);
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric'
	});
}

function renderStars(rating: number) {
	return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}

const getGoodreadsUrl = (id: string) =>
	`https://www.goodreads.com/book/show/${id}`;
---

<Base head={{ title: pageTitle, description: pageDescription }}>
	<Section>
		<Heading title="Books" />
	</Section>

	<CurrentlyReading
		books={currentlyReading}
		getGoodreadsUrl={getGoodreadsUrl}
	/>

	<BookList
		readHistory={readHistory}
		years={years}
		formatDate={formatDate}
		renderStars={renderStars}
		getGoodreadsUrl={getGoodreadsUrl}
	/>
</Base>