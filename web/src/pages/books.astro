---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import Heading from '@/components/Heading.astro';
import { parseBooks, getCurrentlyReading, getReadHistory } from '@/utils/books';

const books = parseBooks();
const currentlyReading = getCurrentlyReading(books);
const readHistory = getReadHistory(books);
const years = Object.keys(readHistory).sort((a, b) => b.localeCompare(a));

const pageTitle = 'Books';
const pageDescription = 'A list of books I am currently reading and have read in the past.';

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}

function renderStars(rating: number) {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}

const getGoodreadsUrl = (id: string) => `https://www.goodreads.com/book/show/${id}`;
---

<Base head={{ title: pageTitle, description: pageDescription }}>
	<Section>
		<Heading title="Books" />
	</Section>

	{currentlyReading.length > 0 && (
		<Section>
			<div class="mb-4 flex items-center gap-3">
				<h2 class="text-2xl font-bold text-[var(--accent-500)]">
					Currently Reading
				</h2>
			</div>
			<div class="grid gap-4">
				{currentlyReading.map((book) => (
					<a href={getGoodreadsUrl(book.id)} target="_blank" rel="noopener noreferrer" class="group block">
						<div class="bg-[var(--card-outer-bg)] p-[1px] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.4)] transition group-hover:bg-[var(--accent-500)]">
							<div class="bg-[var(--card-inner-bg)] p-5 text-[var(--text-color)] opacity-95">
								<h3 class="text-xl font-bold transition group-hover:text-[var(--accent-500)] group-hover:underline">{book.title}</h3>
								<p class="text-[var(--muted-text)]">by {book.author}</p>
							</div>
						</div>
					</a>
				))}
			</div>
		</Section>
	)}

	<Section>
		<h2 class="mb-4 text-2xl font-bold text-[var(--accent-500)]">
			Reading History
		</h2>
		<div class="flex flex-col gap-16">
			{years.map((year) => {
				const booksInYear = readHistory[year] ?? [];
				return (
				<div>
					<h3 class="mb-6 flex items-center gap-4 border-b border-[var(--border-color)] pb-2 text-xl font-bold text-[var(--text-color)]">
						<span class="text-[var(--accent-500)]">#</span> {year}
						<span class="text-xs font-normal text-[var(--muted-text)] ml-auto">
							{booksInYear.length} books
						</span>
					</h3>
					
					{/* Desktop Table View */}
					<div class="hidden md:block overflow-x-auto">
						<table class="w-full text-left text-sm">
							<thead>
								<tr class="border-b border-[var(--border-color)] text-[var(--muted-text)]">
									<th class="pb-3 pr-4 font-bold uppercase tracking-wider text-[10px]">Title</th>
									<th class="pb-3 pr-4 font-bold uppercase tracking-wider text-[10px]">Author</th>
									<th class="pb-3 pr-4 font-bold uppercase tracking-wider text-[10px] whitespace-nowrap">Completed</th>
									<th class="pb-3 pr-4 font-bold uppercase tracking-wider text-[10px]">Reads</th>
									<th class="pb-3 font-bold uppercase tracking-wider text-[10px]">Rating</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-[var(--border-color)]/30">
								{booksInYear.map((book) => (
									<tr class="group hover:bg-[var(--accent-500)]/5 transition-colors">
										<td class="py-4 pr-4">
											<a href={getGoodreadsUrl(book.id)} target="_blank" rel="noopener noreferrer" class="font-bold text-[var(--text-color)] group-hover:text-[var(--accent-500)] group-hover:underline">
												{book.title}
											</a>
										</td>
										<td class="py-4 pr-4 text-[var(--muted-text)]">
											{book.author}
										</td>
										<td class="py-4 pr-4 text-[var(--muted-text)] whitespace-nowrap">
											{book.dateRead ? formatDate(book.dateRead) : '-'}
										</td>
										<td class="py-4 pr-4 text-[var(--muted-text)]">
											{book.readCount}
										</td>
										<td class="py-4 font-mono text-[var(--accent-500)] tracking-tighter">
											{renderStars(book.rating)}
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					{/* Mobile Card View */}
					<div class="flex flex-col gap-6 md:hidden">
						{booksInYear.map((book) => (
							<div class="border-b border-[var(--border-color)] pb-6 last:border-0">
								<a href={getGoodreadsUrl(book.id)} target="_blank" rel="noopener noreferrer" class="group block">
									<h4 class="mb-1 font-bold text-[var(--text-color)] group-hover:text-[var(--accent-500)] group-hover:underline">{book.title}</h4>
								</a>
								<p class="mb-3 text-xs text-[var(--muted-text)]">by {book.author}</p>
								<div class="flex flex-wrap items-center gap-y-2 text-[10px] uppercase tracking-wider">
									<div class="mr-4">
										<span class="font-bold text-[var(--muted-text)]">Completed:</span>
										<span class="ml-1 text-[var(--text-color)]">{book.dateRead ? formatDate(book.dateRead) : '-'}</span>
									</div>
									<div class="mr-4">
										<span class="font-bold text-[var(--muted-text)]">Reads:</span>
										<span class="ml-1 text-[var(--text-color)]">{book.readCount}</span>
									</div>
									<div>
										<span class="font-bold text-[var(--muted-text)] mr-1">Rating:</span>
										<span class="font-mono text-[var(--accent-500)] tracking-tighter">{renderStars(book.rating)}</span>
									</div>
								</div>
							</div>
						))}
					</div>
				</div>
				);
			})}
		</div>
	</Section>
</Base>
