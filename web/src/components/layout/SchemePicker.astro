---
import { siteConfig } from '@/config/site.config';
import { schemes } from '@/styles/schemes';

interface Props {
	id: string;
	menuId: string;
	align?: 'left' | 'right';
	width?: 'narrow' | 'wide';
}
const { id, menuId, align = 'right', width = 'narrow' } = Astro.props;
const positionClass = align === 'right' ? 'right-0' : 'left-0';
const widthClass = width === 'wide' ? 'w-56' : 'min-w-44';
const optionTextClass = width === 'wide' ? 'text-sm' : '';
const checkSize = width === 'wide' ? 'h-5 w-5 shrink-0' : 'h-4 w-4';
const labelClass = width === 'wide' ? 'min-w-0 flex-1 truncate' : '';

const orderedSchemes = siteConfig.schemes.list.map((name) => ({ name, ...schemes[name] }));
---

<div class="relative">
	<button
		id={id}
		class="tada cursor-pointer p-2"
		type="button"
		aria-haspopup="menu"
		aria-expanded="false"
		aria-controls={menuId}
	>
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M12 3a9 9 0 1 0 9 9 3 3 0 0 1-3-3 6 6 0 0 0-6-6Z" class="fill-[var(--text-color)]/30" />
			<path d="M12 3a6 6 0 0 1 6 6 3 3 0 0 0 3 3 9 9 0 1 1-9-9Z" class="fill-[var(--accent-500)]" />
		</svg>
		<span class="sr-only">Open color scheme menu</span>
	</button>
	<div
		id={menuId}
		role="menu"
		class={`scheme-menu absolute ${positionClass} top-full z-50 mt-2 hidden ${widthClass} rounded-md border border-[var(--border-color)] bg-[var(--card-inner-bg)] p-1 shadow-lg`}
	>
		{orderedSchemes.map((scheme) => (
			<button
				data-scheme={scheme.name}
				role="menuitem"
				class={`scheme-option group flex w-full items-center gap-2 rounded-sm px-3 py-2 text-left hover:bg-[var(--card-outer-bg)] ${optionTextClass}`}
			>
				<span class="h-3 w-3 rounded-full" style={`background-color:${scheme.swatch}`}></span>
				<span class={labelClass}>{scheme.label}</span>
				<svg class={`ml-auto hidden ${checkSize} text-[var(--accent-500)]`} viewBox="0 0 20 20" fill="currentColor"
				><path d="M16.707 5.293a1 1 0 0 1 0 1.414l-7.25 7.25a1 1 0 0 1-1.414 0l-3-3a1 1 0 1 1 1.414-1.414L8.5 11.586l6.543-6.543a1 1 0 0 1 1.414 0Z" /></svg>
			</button>
		))}
	</div>
</div>
