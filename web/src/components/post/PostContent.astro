---
import Section from '../layout/Section.astro';
---

<Section>
    <div
		class="content prose prose-img:rounded-lg prose-img:shadow-xl mt-8 max-w-none text-base leading-8 text-[var(--text-color)]"
	>
		<slot />
	</div>
</Section>

<script>
	function addCopyButtons() {
		const blocks = document.querySelectorAll<HTMLPreElement>('.content pre:not(.mermaid)');
		for (const pre of blocks) {
			if (pre.querySelector('.copy-btn')) continue;
			const code = pre.querySelector('code');
			if (!code) continue;

			const btn = document.createElement('button');
			btn.className = 'copy-btn';
			btn.textContent = 'copy';
			btn.setAttribute('aria-label', 'Copy code to clipboard');

			btn.addEventListener('click', async () => {
				try {
					await navigator.clipboard.writeText(code.innerText);
					btn.textContent = 'copied!';
					btn.classList.add('copied');
					setTimeout(() => {
						btn.textContent = 'copy';
						btn.classList.remove('copied');
					}, 2000);
				} catch {
					btn.textContent = 'error';
					setTimeout(() => {
						btn.textContent = 'copy';
					}, 2000);
				}
			});

			pre.appendChild(btn);
		}
	}

	document.addEventListener('astro:page-load', addCopyButtons);
</script>
