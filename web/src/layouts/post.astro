---
import Base from '@/layouts/Base.astro';
import PostHeader from '@/components/PostHeader.astro';
import PostContent from '@/components/PostContent.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import type { MarkdownHeading } from 'astro';

const { frontmatter, headings = [] } = Astro.props as {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  frontmatter: Record<string, any>;
  headings: MarkdownHeading[];
};

const slug = Astro.url.pathname.replace(/\/$/, '').split('/').pop()!;
const ogImage = new URL(`/og/${slug}.png`, Astro.site).toString();

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;
---

<Base
	head={{
		title: frontmatter.title,
		description: frontmatter.description,
		type: 'article',
		image: ogImage,
		article: {
			publishedTime: new Date(frontmatter.pubDate).toISOString(),
			author: frontmatter.author,
			tags: frontmatter.tags,
		},
	}}
>
	<Fragment slot="head">
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'BlogPosting',
			headline: frontmatter.title,
			description: frontmatter.description,
			author: {
				'@type': 'Person',
				name: frontmatter.author,
				url: 'https://kgdev.me',
			},
			publisher: {
				'@type': 'Person',
				name: frontmatter.author,
				url: 'https://kgdev.me',
			},
			datePublished: new Date(frontmatter.pubDate).toISOString(),
			url: Astro.url.href,
			image: ogImage,
			keywords: (frontmatter.tags ?? []).join(', '),
		})} />
	</Fragment>
	<div class={showToc ? 'post-outer post-has-toc' : 'post-outer'}>
		<div class="post-main">
			<PostHeader
				title={frontmatter.title}
				author={frontmatter.author}
				tags={frontmatter.tags}
				minutesRead={frontmatter.minutesRead}
				pubDate={frontmatter.pubDate}
				slug={slug}
				isPinned={frontmatter.isPinned}
				img={{ src: frontmatter.image.src, alt: frontmatter.image.alt }}
			/>
			<PostContent><slot /></PostContent>
		</div>
		{showToc && (
			<aside class="post-toc" aria-label="Table of contents">
				<TableOfContents headings={tocHeadings} />
			</aside>
		)}
	</div>
</Base>
