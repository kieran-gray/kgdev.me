---
import Section from '@/components/layout/Section.astro';
import {
	type Book,
	formatBookDate,
	getGoodreadsUrl,
	renderBookStars
} from '@/lib/content/books';

interface Props {
	readHistory: Record<string, Book[]>;
	years: string[];
}

const { readHistory, years } = Astro.props as Props;
---

<Section>
	<h2 class="mb-4 text-2xl font-bold text-[var(--accent-500)]">
		Reading History
	</h2>

	<div class="flex flex-col gap-16">
		{years.map((year) => {
			const booksInYear = readHistory[year] ?? [];

			return (
				<div>
					<h3 class="mb-6 flex items-center gap-4 border-b border-[var(--border-color)] pb-2 text-xl font-bold text-[var(--text-color)]">
						<span class="text-[var(--accent-500)]">#</span> {year}
						<span class="ml-auto text-xs font-normal text-[var(--muted-text)]">
							{booksInYear.length} books
						</span>
					</h3>

					{/* Desktop Table */}
					<div class="hidden overflow-x-auto md:block">
						<table class="w-full text-left text-sm">
							<thead>
								<tr class="border-b border-[var(--border-color)] text-[var(--muted-text)]">
									<th class="pr-4 pb-3 text-[10px] font-bold tracking-wider uppercase">
										Title
									</th>
									<th class="pr-4 pb-3 text-[10px] font-bold tracking-wider uppercase">
										Author
									</th>
									<th class="pr-4 pb-3 text-[10px] font-bold tracking-wider whitespace-nowrap uppercase">
										Completed
									</th>
									<th class="pr-4 pb-3 text-[10px] font-bold tracking-wider uppercase">
										Reads
									</th>
									<th class="pb-3 text-[10px] font-bold tracking-wider uppercase">
										Rating
									</th>
								</tr>
							</thead>

							<tbody class="divide-y divide-[var(--border-color)]/30">
								{booksInYear.map((book) => (
									<tr class="group transition-colors hover:bg-[var(--accent-500)]/5">
										<td class="py-4 pr-4">
											<a
												href={getGoodreadsUrl(book.id)}
												target="_blank"
												rel="noopener noreferrer"
												class="font-bold text-[var(--text-color)] group-hover:text-[var(--accent-500)] group-hover:underline"
											>
												{book.title}
											</a>
										</td>

										<td class="py-4 pr-4 text-[var(--muted-text)]">
											{book.author}
										</td>

										<td class="py-4 pr-4 whitespace-nowrap text-[var(--muted-text)]">
											{book.dateRead
												? formatBookDate(book.dateRead)
												: '-'}
										</td>

										<td class="py-4 pr-4 text-[var(--muted-text)]">
											{book.readCount}
										</td>

										<td class="py-4 font-mono tracking-tighter text-[var(--accent-500)]">
											{renderBookStars(book.rating)}
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					{/* Mobile Cards */}
					<div class="flex flex-col gap-6 md:hidden">
						{booksInYear.map((book) => (
							<div class="border-b border-[var(--border-color)] pb-6 last:border-0">
								<a
									href={getGoodreadsUrl(book.id)}
									target="_blank"
									rel="noopener noreferrer"
									class="group block"
								>
									<h4 class="mb-1 font-bold text-[var(--text-color)] group-hover:text-[var(--accent-500)] group-hover:underline">
										{book.title}
									</h4>
								</a>

								<p class="mb-3 text-xs text-[var(--muted-text)]">
									by {book.author}
								</p>

								<div class="flex flex-wrap items-center gap-y-2 text-[10px] tracking-wider uppercase">
									<div class="mr-4">
										<span class="font-bold text-[var(--muted-text)]">
											Completed:
										</span>
										<span class="ml-1 text-[var(--text-color)]">
											{book.dateRead
												? formatBookDate(book.dateRead)
												: '-'}
										</span>
									</div>

									<div class="mr-4">
										<span class="font-bold text-[var(--muted-text)]">
											Reads:
										</span>
										<span class="ml-1 text-[var(--text-color)]">
											{book.readCount}
										</span>
									</div>

									<div>
										<span class="mr-1 font-bold text-[var(--muted-text)]">
											Rating:
										</span>
										<span class="font-mono tracking-tighter text-[var(--accent-500)]">
											{renderBookStars(book.rating)}
										</span>
									</div>
								</div>
							</div>
						))}
					</div>
				</div>
			);
		})}
	</div>
</Section>
