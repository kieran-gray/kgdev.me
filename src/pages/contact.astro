---
import Base from '@/layouts/Base.astro';
import Section from '@/components/Section.astro';
import AsciiHeader from '@/components/AsciiHeader.astro';
import { AppConfig } from '@/utils/AppConfig';

const title = `Contact | ${AppConfig.title}`;
const description = 'Get in touch for professional inquiries or just to say hi.';
---

<Base head={{ title, description }}>
  <Section>
    <div class="mt-8 flex flex-col items-center">
      <AsciiHeader text="CONTACT" />
      <p class="mt-4 text-center text-lg text-[var(--accent-600)]">
        Professional inquiries, collaborations, or just a friendly hello.
      </p>
    </div>

    <div class="relative mx-auto mt-12 max-w-2xl">
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-bold text-[var(--accent-700)] uppercase tracking-wider">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="mt-1 block w-full border-2 border-[var(--accent-200)] bg-[var(--page-bg)] px-4 py-3 font-mono text-[var(--text-color)] focus:border-[var(--accent-500)] focus:outline-none transition-colors"
            placeholder="Your Name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-bold text-[var(--accent-700)] uppercase tracking-wider">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-1 block w-full border-2 border-[var(--accent-200)] bg-[var(--page-bg)] px-4 py-3 font-mono text-[var(--text-color)] focus:border-[var(--accent-500)] focus:outline-none transition-colors"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-bold text-[var(--accent-700)] uppercase tracking-wider">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="mt-1 block w-full border-2 border-[var(--accent-200)] bg-[var(--page-bg)] px-4 py-3 font-mono text-[var(--text-color)] focus:border-[var(--accent-500)] focus:outline-none transition-colors"
            placeholder="What's on your mind?"
          ></textarea>
        </div>

        <div class="flex justify-center min-h-[65px]">
          <div id="turnstile-container"></div>
        </div>

        <div class="flex justify-center">
          <button
            type="submit"
            id="submit-btn"
            class="group relative overflow-hidden border-2 border-[var(--accent-500)] px-8 py-3 font-bold uppercase tracking-widest text-[var(--accent-700)] transition-all hover:bg-[var(--accent-500)] hover:text-white disabled:opacity-50"
          >
            <span class="relative z-10">Send Message</span>
          </button>
        </div>
      </form>

      <!-- Overlay -->
      <div
        id="form-overlay"
        class="absolute inset-[-20px] z-50 flex hidden items-center justify-center bg-[var(--page-bg)]/80 backdrop-blur-sm transition-opacity duration-300"
      >
        <div class="text-center w-full overflow-hidden px-4">
          <pre id="status-ascii" class="inline-block text-left text-[0.35rem] font-bold leading-[1] text-[var(--accent-700)] sm:text-[0.45rem] md:text-[0.6rem] lg:text-[0.7rem]"></pre>
        </div>
      </div>
    </div>
  </Section>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"></script>

  <script>
    import { generateAsciiArtText } from '@/utils/asciiArt';

    const CONTACT_URL = import.meta.env.PUBLIC_CONTACT_URL ?? 'https://contact.kgdev.me/api/v1/contact/';

    function initContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const overlay = document.getElementById('form-overlay') as HTMLDivElement;
      const statusAscii = document.getElementById('status-ascii') as HTMLPreElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      let turnstileToken = '';

      if (!form) return;

      const turnstileContainer = document.getElementById('turnstile-container');

      // @ts-ignore
      if (turnstileContainer && typeof turnstile !== 'undefined') {
        // @ts-ignore
        turnstile.render('#turnstile-container', {
          sitekey: '0x4AAAAAADFJ-aGGTpoBJuyq',
          callback: (token: string) => {
            turnstileToken = token;
          },
        });
      }

      async function animateText(text: string) {
        statusAscii.textContent = '';
        for (let i = 1; i <= text.length; i++) {
          const partialText = text.substring(0, i);
          statusAscii.textContent = generateAsciiArtText(partialText, { spacing: 1 });
          await new Promise(resolve => setTimeout(resolve, 100));
        }
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!turnstileToken && !window.location.hostname.includes('localhost')) {
          alert('Please complete the Turnstile challenge.');
          return;
        }

        const formData = new FormData(form);
        const name = formData.get('name');
        const email = formData.get('email');
        const message = formData.get('message');

        overlay.classList.remove('hidden');
        submitBtn.disabled = true;

        const animationPromise = animateText('SENDING...');
        const minimumDelayPromise = new Promise(resolve => setTimeout(resolve, 1000));
        
        const apiPromise = fetch(CONTACT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message, token: turnstileToken })
        }).then(res => res.json() as Promise<{ success: boolean; error?: string }>);

        try {
          const [_, response] = await Promise.all([
            Promise.all([animationPromise, minimumDelayPromise]),
            apiPromise
          ]);

          if (response.success) {
            statusAscii.textContent = generateAsciiArtText('SENT!', { spacing: 1 });
            form.reset();
            // @ts-ignore
            if (typeof turnstile !== 'undefined') {
              // @ts-ignore
              turnstile.reset();
              turnstileToken = '';
            }
          } else {
            console.error('Backend error:', response.error);
            statusAscii.textContent = generateAsciiArtText('ERROR!', { spacing: 1 });
            // @ts-ignore
            if (typeof turnstile !== 'undefined') {
              // @ts-ignore
              turnstile.reset();
              turnstileToken = '';
            }
          }
          
          setTimeout(() => {
            overlay.classList.add('hidden');
            submitBtn.disabled = false;
          }, 3000);

        } catch (error) {
          console.error('Failed to send message:', error);
          await animationPromise;
          statusAscii.textContent = generateAsciiArtText('ERROR!', { spacing: 1 });
          setTimeout(() => {
            overlay.classList.add('hidden');
            submitBtn.disabled = false;
          }, 3000);
        }
      });
    }
    document.addEventListener('astro:page-load', initContactForm);
  </script>

  <style>
    #status-ascii {
      white-space: pre;
      line-height: 1;
    }
  </style>
</Base>
