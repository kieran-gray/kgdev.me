---
import { getTagDisplay } from '@/lib/format/tagDisplay';

interface Props {
	tag: string;
	withHref?: boolean;
}

const { tag, withHref } = Astro.props;
const displayTag = getTagDisplay(tag);
---

<span
	class={`mb-2 mr-2 bg-[var(--tag-bg)] px-3 py-1 text-xs font-bold uppercase text-[var(--tag-text)] group-hover:bg-[var(--tag-bg-hover)] ${
		withHref ? 'hover:bg-[var(--tag-bg-hover)]' : ''
	}`}
>
	#{displayTag}
</span>
