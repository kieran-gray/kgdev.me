---
import Section from '../layout/Section.astro';
import Card from '../ui/Card.astro';
import type { PostEntry } from '@/lib/content/posts';

interface Props {
	posts: PostEntry[];
}

const { posts } = Astro.props;
---

<Section>
	<div class="flex justify-between pb-4">
		<p class="text-xl font-bold">Latest Posts</p>
		<a href="/posts" class="underline hover:text-[var(--accent-500)]">all posts →</a>
	</div>
	<div class="flex flex-col pb-4 md:flex-row">
		{
			posts.map((post) => (
				<div class="mb-4 basis-1 last:mr-0 md:mr-4 md:basis-1/3">
					<Card post={post} showExcerpt={false} />
				</div>
			))
		}
	</div>
</Section>
