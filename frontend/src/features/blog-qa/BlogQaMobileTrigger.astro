---
import Sparkle from 'phosphor-astro/SparkleDuotone.astro';
---
<div class="blog-qa-mobile-wrap">
	<button type="button" class="blog-qa-mobile-trigger" id="blog-qa-mobile-open">
		<Sparkle width={16} height={16} />
		<span>Ask AI about this post</span>
	</button>
</div>

<script>
	function setup() {
		document.getElementById('blog-qa-mobile-open')?.addEventListener('click', () => {
			(document.getElementById('blog-qa-open') as HTMLButtonElement | null)?.click();
		});
	}

	document.addEventListener('astro:page-load', setup);
</script>
